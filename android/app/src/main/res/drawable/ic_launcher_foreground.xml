<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground for Snehkriti.
  Canvas is 108dp x 108dp (Android adaptive icon spec).
  Safe zone: 72dp centered (18dp inset each side).
  Logo: "स्नेह" (Hindi, bold, brown) + "Kriti" (italic, gold) + "CUSTOMISED CLOTHES" (spaced caps, muted)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Subtle warm glow circle behind text -->
    <path
        android:fillColor="#1AD4A373"
        android:pathData="M54,54 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0" />

    <!-- Thin decorative ring -->
    <path
        android:strokeColor="#30D4A373"
        android:strokeWidth="0.6"
        android:fillColor="#00000000"
        android:pathData="M54,54 m-44,0 a44,44 0 1,0 88,0 a44,44 0 1,0 -88,0" />

    <!-- "स्नेह" — rendered as a text path approximation.
         Since Android VectorDrawable does not support <text>, we use a
         placeholder decorative shape here. The actual Hindi text is set
         via the ic_launcher_foreground drawable being replaced by a
         bitmap in each mipmap density folder via the Python script below.
         This vector serves as the adaptive icon foreground shape/color guide. -->

    <!-- Top decorative dot row -->
    <path android:fillColor="#40A17852"
        android:pathData="M44,28 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0" />
    <path android:fillColor="#40D4A373"
        android:pathData="M52.5,28 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0" />
    <path android:fillColor="#40A17852"
        android:pathData="M61,28 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0" />

    <!-- "स्नेह" block — bold brown rectangle stand-in (replaced by bitmap icons) -->
    <!-- Hindi text area indicator: warm brown band -->
    <path
        android:fillColor="#A17852"
        android:pathData="M22,36 Q54,32 86,36 L86,38 Q54,34 22,38 Z"
        android:fillAlpha="0.15"/>

    <!-- Main Hindi text: स्नेह — approximated with stylized strokes -->
    <!-- Horizontal top bar (like Devanagari shirorekha) -->
    <path
        android:strokeColor="#A17852"
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M26,40 L82,40" />

    <!-- स — left vertical + curve -->
    <path
        android:strokeColor="#A17852"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M29,40 L29,52 Q29,56 33,56 Q37,56 37,52 L37,48 Q37,44 33,44" />

    <!-- ् (halant) + न -->
    <path
        android:strokeColor="#A17852"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M40,40 L40,56 M40,48 L48,48 L48,40 L48,56" />

    <!-- े (e matra) above न -->
    <path
        android:strokeColor="#A17852"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M40,37 Q44,34 48,37" />

    <!-- ह -->
    <path
        android:strokeColor="#A17852"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M52,40 L52,56 M52,48 L60,48 M60,40 L60,56 M60,52 Q62,58 58,58" />

    <!-- "Kriti" — italic serif style in gold -->
    <!-- K -->
    <path
        android:strokeColor="#D4A373"
        android:strokeWidth="2.0"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M24,63 L24,76 M24,69 L31,63 M24,69 L31,76" />

    <!-- r -->
    <path
        android:strokeColor="#D4A373"
        android:strokeWidth="2.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M34,67 L34,76 M34,69 Q37,66 40,68" />

    <!-- i -->
    <path
        android:strokeColor="#D4A373"
        android:strokeWidth="2.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M43,67 L43,76" />
    <!-- i dot -->
    <path
        android:fillColor="#D4A373"
        android:pathData="M42,64 a1,1 0 1,0 2,0 a1,1 0 1,0 -2,0" />

    <!-- t -->
    <path
        android:strokeColor="#D4A373"
        android:strokeWidth="2.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M48,63 L48,76 M45,67 L51,67" />

    <!-- i -->
    <path
        android:strokeColor="#D4A373"
        android:strokeWidth="2.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M54,67 L54,76" />
    <!-- i dot -->
    <path
        android:fillColor="#D4A373"
        android:pathData="M53,64 a1,1 0 1,0 2,0 a1,1 0 1,0 -2,0" />

    <!-- Italic slant underline for "Kriti" -->
    <path
        android:strokeColor="#D4A373"
        android:strokeWidth="0.8"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M23,78 L57,78"
        android:fillAlpha="0.5"/>

    <!-- Thin divider -->
