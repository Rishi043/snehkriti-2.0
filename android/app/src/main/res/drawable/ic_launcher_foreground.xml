        android:strokeColor="#D4A373"
        android:strokeWidth="0.5"
        android:fillColor="#00000000"
        android:pathData="M28,82 L80,82"
        android:fillAlpha="0.4"/>

    <!-- "CUSTOMISED CLOTHES" — tiny dots representing spaced text -->
    <path android:fillColor="#A17852" android:fillAlpha="0.6"
        android:pathData="M28,86 L30,86 L30,87.5 L28,87.5 Z"/>
    <path android:fillColor="#A17852" android:fillAlpha="0.6"
        android:pathData="M32,86 L34,86 L34,87.5 L32,87.5 Z"/>
